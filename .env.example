# ============================================================
# AgentOrchestra - ملف متغيرات البيئة (مثال)
# ============================================================
# انسخ هذا الملف إلى .env وأضف قيمك الحقيقية:
#   cp .env.example .env
#
# ⚠️  لا ترفع ملف .env إلى Git أبداً!
#     .env مُدرج في .gitignore تلقائياً.
# ============================================================


# ── Groq API ────────────────────────────────────────────────
# احصل على المفتاح من: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=8000
GROQ_TIMEOUT=60


# ── Google Gemini API ────────────────────────────────────────
# احصل على المفتاح من: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro


# ── Anthropic Claude API ─────────────────────────────────────
# احصل على المفتاح من: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-7-sonnet-20250219


# ── GitHub Personal Access Token ────────────────────────────
# أنشئ Token من: https://github.com/settings/tokens
# الصلاحيات المطلوبة: repo, workflow
GITHUB_TOKEN=your_github_personal_access_token_here


# ── Telegram Bot ─────────────────────────────────────────────
# أنشئ Bot عبر @BotFather في تيليغرام
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here


# ── Gmail ────────────────────────────────────────────────────
# استخدم App Password (لا كلمة المرور الحقيقية)
# من: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here


# ── SerpAPI (اختياري - للبحث المتقدم) ───────────────────────
# احصل على المفتاح من: https://serpapi.com
SERP_API_KEY=your_serp_api_key_here


# ── Flask Server ─────────────────────────────────────────────
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false
# غيّر هذا إلى قيمة عشوائية طويلة في الإنتاج!
FLASK_SECRET_KEY=change-me-to-a-random-secret-key-in-production


# ── Logging ──────────────────────────────────────────────────
# المستويات: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=30
# true = JSON format, false = نص عادي
LOG_JSON_FORMAT=false


# ── Execution ────────────────────────────────────────────────
MAX_WORKERS=7
WORKER_TIMEOUT=1800
MAX_RETRIES=3
CRITIC_MAX_ROUNDS=5
INFINITE_LOOP_THRESHOLD=3


# ── Env Encryption (Phase 1) ─────────────────────────────────
# تفعيل/تعطيل تشفير ملفات .env (اختياري)
ENV_ENCRYPTION_ENABLED=false
# مفتاح Fernet بصيغة Base64 (32-byte key). يُنشأ عبر: python -m utils.env_encryption
ENV_ENCRYPTION_KEY=your_fernet_key_here
